TELEGRAM_CODEX_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ADMIN_USER_IDS=123456789
TELEGRAM_ALLOWED_USER_IDS=123456789

# By default the bridge works inside tg-manager.
CODEX_PROJECT_DIR=..
CODEX_CMD=
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL=never
CODEX_TIMEOUT_SECONDS=900
CODEX_HISTORY_TURNS=8
CODEX_CONFIRM_BEFORE_RUN=false
ALLOW_ALL_TELEGRAM_USERS=false
TELEGRAM_MAX_FILE_BYTES=1048576
TELEGRAM_MAX_FILE_CHARS=60000
TELEGRAM_PROGRESS_SECONDS=300
