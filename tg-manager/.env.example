MANAGER_BOT_TOKEN=123456789:AAF...
DATABASE_URL=postgresql://user:password@localhost:5432/tgmanager
# Comma-separated Telegram user IDs allowed to use the manager
ADMIN_IDS=123456789,987654321
# Delay between messages in broadcast (seconds)
BROADCAST_DELAY=0.05
# Max concurrent API calls to managed bots
MAX_CONCURRENT=20
