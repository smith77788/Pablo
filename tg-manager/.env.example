# ── Обязательные ──────────────────────────────────────────────────────────
# DEPLOYMENT TRIGGER: 2026-05-28T10:35:00Z — Force Railway rebuild for v2026.05.28-r3
MANAGER_BOT_TOKEN=replace-with-manager-bot-token

# Для Docker Compose (DATABASE_URL формируется автоматически из POSTGRES_*)
POSTGRES_USER=tgmanager
POSTGRES_PASSWORD=tgmanager123
POSTGRES_DB=tgmanager

# Для прямого запуска без Docker
DATABASE_URL=postgresql://tgmanager:tgmanager123@localhost:5432/tgmanager

# ── Опциональные ──────────────────────────────────────────────────────────
# Telegram user_id администраторов через запятую
ADMIN_IDS=123456789,987654321

# Задержка между сообщениями при рассылке (секунды)
BROADCAST_DELAY=0.05

# Параллельных воркеров рассылки
MAX_CONCURRENT=20

# Максимальный размер файла для AI-ассистента
AI_FILE_MAX_BYTES=1048576
AI_FILE_MAX_CHARS=60000

# AI provider failover for BotMother Assistant.
# Set at least one key. The assistant tries providers in AI_PROVIDER_ORDER.
AI_PROVIDER_ORDER=openrouter,groq,gemini

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_MODELS=google/gemini-2.0-flash-exp:free,meta-llama/llama-3.2-3b-instruct:free,mistralai/mistral-7b-instruct:free

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash
