# ═══════════════════════════════════════════════════════════
# Nevesty Models + AI Office Factory — все переменные
# Скопируйте в .env и заполните свои значения
# ═══════════════════════════════════════════════════════════

# ── Anthropic / Claude API ────────────────────────────────
# Получить на: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Модель для AI Factory (по умолчанию claude-sonnet-4-6)
FACTORY_MODEL=claude-sonnet-4-6

# Интервал автономного цикла в часах (по умолчанию 6)
FACTORY_CYCLE_HOURS=6

# Таймаут запроса к Claude в секундах (по умолчанию 300)
FACTORY_TIMEOUT=300

# ── Telegram Bot ──────────────────────────────────────────
# Создать бота у @BotFather
BOT_TOKEN=123456789:AAF...
TELEGRAM_BOT_TOKEN=123456789:AAF...  # alias used by some modules
BOT_USERNAME=YourBotUsername

# ID администраторов через запятую (узнать через @userinfobot)
ADMIN_TELEGRAM_IDS=123456789

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# JWT для веб-панели
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа

# URL сайта (для ссылок в боте)
SITE_URL=https://your-domain.com

# Webhook (опционально — если пустой, используется polling)
WEBHOOK_URL=

# ── Контакты агентства ────────────────────────────────────
AGENCY_PHONE=+7 (800) 555-00-00
AGENCY_EMAIL=info@nevesty-models.ru

# ── Admin credentials (начальная настройка) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=измените_при_первом_входе

# ── Supabase (опционально — альтернатива SQLite) ──────────
# Получить на: https://supabase.com/
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Email (опционально) ───────────────────────────────────
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your@email.com
# EMAIL_PASSWORD=app-password-here
