// This is your Prisma schema file.
// Multi-tenant Telegram SaaS platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS ─────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter") // starter|pro|enterprise
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bots          Bot[]
  operators     Operator[]
  telegramUsers TelegramUser[]
  conversations Conversation[]
  messages      Message[]
  broadcasts    Broadcast[]
  templates     Template[]
  tags          Tag[]
  segments      Segment[]
  automations   Automation[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]

  @@map("tenants")
}

// ─── OPERATORS (platform users) ──────────────────────────────────────────────

model Operator {
  id           String       @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  avatarUrl    String?
  role         OperatorRole @default(AGENT)
  isActive     Boolean      @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]     @relation("AssignedOperator")
  sentMessages        Message[]
  notes               InternalNote[]
  refreshTokens       RefreshToken[]

  @@unique([tenantId, email])
  @@map("operators")
}

enum OperatorRole {
  OWNER
  ADMIN
  AGENT
}

model RefreshToken {
  id         String   @id @default(uuid())
  operatorId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  keyHash   String   @unique
  lastUsedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── BOTS ─────────────────────────────────────────────────────────────────────

model Bot {
  id          String   @id @default(uuid())
  tenantId    String
  token       String   @unique
  telegramId  BigInt   @unique
  username    String?
  firstName   String
  isActive    Boolean  @default(true)
  webhookUrl  String?
  webhookSet  Boolean  @default(false)
  avatarUrl   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  broadcasts    Broadcast[]
  botCommands   BotCommand[]
  flowNodes     FlowNode[]

  @@index([tenantId])
  @@map("bots")
}

model BotCommand {
  id           String   @id @default(uuid())
  botId        String
  command      String
  description  String
  languageCode String   @default("")
  createdAt    DateTime @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, command, languageCode])
  @@map("bot_commands")
}

// ─── TELEGRAM USERS (end users / subscribers) ────────────────────────────────

model TelegramUser {
  id           String   @id @default(uuid())
  tenantId     String
  telegramId   BigInt
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  isPremium    Boolean  @default(false)

  // CRM fields
  email        String?
  phone        String?
  notes        String?
  customFields Json     @default("{}")

  // Lifecycle
  activationScore Float    @default(0)
  retentionScore  Float    @default(0)
  ltv             Float    @default(0)

  firstSeenAt  DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  firstBotId   String?
  isBlocked    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  userTags      UserTag[]
  segmentUsers  SegmentUser[]

  @@unique([tenantId, telegramId])
  @@index([tenantId])
  @@index([tenantId, lastSeenAt])
  @@map("telegram_users")
}

// ─── CONVERSATIONS ────────────────────────────────────────────────────────────

model Conversation {
  id        String             @id @default(uuid())
  tenantId  String
  botId     String
  userId    String
  status    ConversationStatus @default(OPEN)
  priority  Priority           @default(NORMAL)

  assignedToId String?
  lockedById   String?
  lockedAt     DateTime?

  subject       String?
  lastMessageAt DateTime?
  firstReplyAt  DateTime?
  resolvedAt    DateTime?
  slaBreachedAt DateTime?

  // SLA
  slaMinutes    Int?
  slaDueAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot        Bot          @relation(fields: [botId], references: [id])
  user       TelegramUser @relation(fields: [userId], references: [id])
  assignedTo Operator?    @relation("AssignedOperator", fields: [assignedToId], references: [id])
  messages   Message[]
  notes      InternalNote[]
  convTags   ConversationTag[]

  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, botId])
  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  LOCKED
  RESOLVED
  SPAM
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── MESSAGES ─────────────────────────────────────────────────────────────────

model Message {
  id             String           @id @default(uuid())
  tenantId       String
  conversationId String
  operatorId     String?

  telegramMessageId Int?
  direction         MessageDirection
  senderType        SenderType
  senderId          String?

  type     MessageType @default(TEXT)
  text     String?
  caption  String?

  // Media
  mediaFileId String?
  mediaUrl    String?
  mediaSize   Int?
  mimeType    String?
  fileName    String?

  // Reply chain
  replyToId String?

  // Relay tracking
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?

  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  editedAt  DateTime?

  metadata Json     @default("{}")
  sentAt   DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  operator     Operator?    @relation(fields: [operatorId], references: [id])
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId, sentAt])
  @@index([tenantId, sentAt])
  @@index([telegramMessageId])
  @@map("messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum SenderType {
  USER
  BOT
  OPERATOR
  SYSTEM
}

enum MessageType {
  TEXT
  PHOTO
  VIDEO
  AUDIO
  VOICE
  DOCUMENT
  STICKER
  ANIMATION
  LOCATION
  CONTACT
  POLL
  VENUE
  GAME
}

// ─── INTERNAL NOTES ───────────────────────────────────────────────────────────

model InternalNote {
  id             String   @id @default(uuid())
  conversationId String
  operatorId     String
  text           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  operator     Operator     @relation(fields: [operatorId], references: [id])

  @@map("internal_notes")
}

// ─── TAGS ─────────────────────────────────────────────────────────────────────

model Tag {
  id       String @id @default(uuid())
  tenantId String
  name     String
  color    String @default("#6366f1")

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTags          UserTag[]
  conversationTags  ConversationTag[]

  @@unique([tenantId, name])
  @@map("tags")
}

model UserTag {
  userId String
  tagId  String

  user TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@map("user_tags")
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

// ─── SEGMENTS ─────────────────────────────────────────────────────────────────

model Segment {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  filters   Json
  userCount Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segmentUsers SegmentUser[]
  broadcasts   Broadcast[]

  @@map("segments")
}

model SegmentUser {
  segmentId String
  userId    String
  addedAt   DateTime @default(now())

  segment Segment      @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user    TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([segmentId, userId])
  @@map("segment_users")
}

// ─── BROADCASTS ───────────────────────────────────────────────────────────────

model Broadcast {
  id        String          @id @default(uuid())
  tenantId  String
  botId     String
  segmentId String?
  name      String
  message   Json
  status    BroadcastStatus @default(DRAFT)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failedCount Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot       Bot       @relation(fields: [botId], references: [id])
  segment   Segment?  @relation(fields: [segmentId], references: [id])
  recipients BroadcastRecipient[]

  @@index([tenantId, status])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String                   @id @default(uuid())
  broadcastId String
  telegramId  BigInt
  status      BroadcastRecipientStatus @default(PENDING)
  sentAt      DateTime?
  errorCode   Int?
  errorMsg    String?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
  @@map("broadcast_recipients")
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
  BLOCKED
}

// ─── TEMPLATES ────────────────────────────────────────────────────────────────

model Template {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  content   Json
  category  String?
  usageCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@map("templates")
}

// ─── AUTOMATION ───────────────────────────────────────────────────────────────

model Automation {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  trigger   Json
  conditions Json    @default("[]")
  actions   Json
  isActive  Boolean  @default(true)
  runCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("automations")
}

// ─── BOT CMS / FLOWS ──────────────────────────────────────────────────────────

model FlowNode {
  id       String  @id @default(uuid())
  botId    String
  type     String
  trigger  String?
  content  Json
  children Json    @default("[]")
  position Json    @default("{\"x\":0,\"y\":0}")
  isStart  Boolean @default(false)
  version  Int     @default(1)

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("flow_nodes")
}

// ─── WEBHOOKS ─────────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(uuid())
  tenantId  String
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}
