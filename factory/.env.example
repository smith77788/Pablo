# ══════════════════════════════════════════════════════════
# Nevesty Models — AI Office Factory Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env && nano .env
# ══════════════════════════════════════════════════════════

# ── Anthropic / Claude API ────────────────────────────────
# Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Model used by the factory (default: claude-sonnet-4-6)
FACTORY_MODEL=claude-sonnet-4-6

# Factory autonomous cycle interval in hours (default: 6)
FACTORY_CYCLE_HOURS=6

# Timeout for Claude API requests in seconds (default: 300)
FACTORY_TIMEOUT=300

# Alert if factory hasn't run in this many hours (default: 12)
FACTORY_ALERT_HOURS=12

# ── Database ──────────────────────────────────────────────
# Path to the main app SQLite DB (relative to /app inside container)
DB_PATH=/app/data/data.db
FACTORY_DB_PATH=/app/data/factory.db

# ── Telegram (for factory notifications) ─────────────────
# Use the same bot token as nevesty-models
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
BOT_TOKEN=your_bot_token_from_botfather

# Comma-separated admin Telegram user IDs
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Server (shared config) ────────────────────────────────
SITE_URL=https://nevesty-models.ru
NODE_ENV=production
