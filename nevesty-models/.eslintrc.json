{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_|^next$|^err$",
      "caughtErrorsIgnorePattern": "^_|^e$|^err$|^error$",
      "varsIgnorePattern": "^_"
    }],
    "no-undef": "error",
    "no-console": "off",
    "eqeqeq": ["warn", "always", { "null": "ignore" }],
    "no-var": "warn",
    "prefer-const": "warn",
    "no-duplicate-case": "error",
    "no-unreachable": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-constant-condition": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "public/",
    "tests/",
    "*.min.js"
  ]
}
