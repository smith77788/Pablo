# ══════════════════════════════════════════════════════════
# Nevesty Models — Environment Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env && nano .env
# ══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Full public URL of the site (used in bot messages, sitemap, OG tags)
SITE_URL=https://nevesty-models.ru
# Webhook URL for Telegram (optional — leave blank to use long polling)
# Must be HTTPS with a valid certificate
WEBHOOK_URL=

# ── Database ──────────────────────────────────────────────
# Path to SQLite database file (relative to project root)
DB_PATH=./data.db
# Use :memory: for ephemeral testing
# DB_PATH=:memory:
DATA_DIR=/app/data

# ── Authentication ────────────────────────────────────────
# Must be at least 32 random characters — generate with:
#   openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d
SESSION_SECRET=your-session-secret-min-32-chars

# ── Admin Account ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_EMAILS=admin@nevesty-models.ru

# ── Telegram Bot ──────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Legacy alias (same value as TELEGRAM_BOT_TOKEN)
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=YourBotUsername

# Comma-separated admin Telegram user IDs (get via @userinfobot)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Telegram channel for content publishing (optional)
# Use @channel_name or numeric ID like -1001234567890
TELEGRAM_CHANNEL_ID=

# ── Agency Contacts ───────────────────────────────────────
AGENCY_PHONE=+7 (800) 555-00-00
AGENCY_EMAIL=info@nevesty-models.ru

# ── Email / SMTP ──────────────────────────────────────────
# Supports Gmail App Password, Yandex, Mailgun SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@nevesty-models.ru
SENDER_NAME=Nevesty Models

# ── SMS Notifications ─────────────────────────────────────────────────────────
# Provider: 'smsru' | 'smsc' | 'twilio' (leave empty to disable SMS)
SMS_PROVIDER=
SMS_FROM=NEVESTY

# SMS.ru (SMS_PROVIDER=smsru)
SMS_RU_API_KEY=your_sms_ru_api_key
# Legacy alias still accepted:
SMS_RU_API_ID=

# SMSC.ru (SMS_PROVIDER=smsc)
SMSC_LOGIN=your_login
SMSC_PASSWORD=your_password

# Twilio (SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── Payment — YooKassa ────────────────────────────────────
# Configure at https://yookassa.ru → Integrations
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Payment — Stripe ──────────────────────────────────────
# Configure at https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── AI Factory ────────────────────────────────────────────
# Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Factory cycle interval in hours (default: 6)
FACTORY_CYCLE_HOURS=6
FACTORY_MODEL=claude-sonnet-4-6
FACTORY_TIMEOUT=300
FACTORY_DB_PATH=../factory/factory.db
# Alert if factory hasn't run in this many hours (default: 12)
FACTORY_ALERT_HOURS=12

# ── CRM Webhooks (optional) ───────────────────────────────
# AmoCRM — incoming webhook URL from Settings → Integrations
AMOCRM_WEBHOOK_URL=
AMOCRM_API_KEY=

# Bitrix24 — outgoing webhook URL from Portal → Integrations
BITRIX24_WEBHOOK_URL=

# Generic outgoing webhook (any CRM or Zapier/Make)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# ── Analytics (optional) ──────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
# Google Analytics 4 alias
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Yandex.Metrica counter ID (numeric)
YM_COUNTER_ID=
YANDEX_METRICA_ID=12345678

# ── WhatsApp (optional) ───────────────────────────────────
# Phone number without + sign, e.g. 79991234567
WHATSAPP_NUMBER=
# WhatsApp Business Cloud API (Meta) — for official template + text messages
# Get at: https://developers.facebook.com/docs/whatsapp/cloud-api/
WHATSAPP_TOKEN=EAAxxxxx_your_system_token
WHATSAPP_PHONE_ID=1234567890123456
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── CORS (optional) ───────────────────────────────────────
# Comma-separated list of allowed origins (blank = allow all)
ALLOWED_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────
# Time window in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per IP per window (default: 100)
RATE_LIMIT_MAX=100

# ── File Upload ───────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Backup ────────────────────────────────────────────────
# Directory for database backups (default: ./backups)
BACKUP_DIR=./backups
# Number of backup files to keep (default: 14)
MAX_BACKUPS=14

# ── Monitoring ────────────────────────────────────────────
# Alert if memory exceeds this MB (default: 500)
MEMORY_ALERT_MB=500
# Optional Bearer token to protect /api/metrics endpoint (blank = public)
# If set, requests must include: Authorization: Bearer <token>
METRICS_TOKEN=

# ── Logging ───────────────────────────────────────────────
# Set to '1' to enable JSON structured logs (auto-enabled in production)
LOG_JSON=0

# ── 2FA (optional) ────────────────────────────────────────
# Enable TOTP-based two-factor authentication for admin panel
TOTP_ENABLED=false

# ── Instagram Graph API ──────────────────────────────────────────────────────────
# Requires Instagram Business Account linked to Facebook Business Manager
# Get from: https://developers.facebook.com/apps
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
