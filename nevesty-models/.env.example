# Server
PORT=3000
NODE_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username_without_at

# Admin Telegram IDs (comma-separated)
ADMIN_TELEGRAM_IDS=123456789,987654321

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this

# Admin credentials (initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Site URL (for links in bot messages)
SITE_URL=http://localhost:3000

# Webhook URL (optional — if set, bot uses webhook instead of polling)
# Must be HTTPS with a valid certificate, e.g. https://your-domain.com
WEBHOOK_URL=

# Agency contact
AGENCY_PHONE=+7 (800) 555-00-00
AGENCY_EMAIL=info@nevesty-models.ru
