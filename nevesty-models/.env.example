# ═══════════════════════════════════════════════
# Nevesty Models — Environment Variables Example
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────
# Create a bot with @BotFather
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=YourBotUsername

# Admin Telegram IDs (comma-separated, get via @userinfobot)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── JWT Authentication ────────────────────────
# Must be at least 32 random characters
JWT_SECRET=your_secure_random_string_min_32_chars

# ── Admin credentials (initial setup) ─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_here

# ── AI Factory ────────────────────────────────
# Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
FACTORY_CYCLE_HOURS=6
FACTORY_MODEL=claude-sonnet-4-6
FACTORY_TIMEOUT=300

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=production

# Site URL (for links in bot messages and sitemap)
SITE_URL=https://nevesty-models.ru

# Webhook URL (optional — if blank, uses long polling)
# Must be HTTPS with valid certificate
WEBHOOK_URL=

# ── Agency contacts ───────────────────────────
AGENCY_PHONE=+7 (800) 555-00-00
AGENCY_EMAIL=info@nevesty-models.ru

# ── CORS (optional) ───────────────────────────
# Comma-separated list of allowed origins
# Leave blank to allow all origins
ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────
DB_PATH=./data.db

# ── Paths (optional) ──────────────────────────
DATA_DIR=/app/data

# ── Email / SMTP ──────────────────────────────
# Use Gmail App Password, Yandex, Mailgun SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@nevesty-models.ru

# Admin email(s) for notifications (comma-separated)
ADMIN_EMAILS=admin@nevesty.ru

# ── SMS Notifications (optional, SMS.ru) ─────
SMS_RU_API_ID=
SMS_FROM=NEVESTY

# ── Payment (optional) ────────────────────────
# Configure payment provider in admin panel → Settings → Оплата
# Set payment_provider to 'yookassa' or 'stripe' via admin panel

# ЮKassa (https://yookassa.ru)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CRM Webhooks (optional) ───────────────────
# AmoCRM — incoming webhook URL from Settings → Integrations
AMOCRM_WEBHOOK_URL=
AMOCRM_API_KEY=

# Bitrix24 — outgoing webhook URL from Portal → Integrations
BITRIX24_WEBHOOK_URL=

# Generic outgoing webhook (any CRM or Zapier/Make)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# ── Backup (optional) ─────────────────────────
# Directory for database backups (default: ./backups)
BACKUP_DIR=./backups
# Number of backup files to keep (default: 14)
MAX_BACKUPS=14

# ── Monitoring ────────────────────────────────
# Alert if factory hasn't run in this many hours (default: 12)
FACTORY_ALERT_HOURS=12
# Alert if memory exceeds this MB (default: 500)
MEMORY_ALERT_MB=500
# Optional token to protect /api/metrics endpoint (leave blank = public)
# If set, requests must include: Authorization: Bearer <token>
METRICS_TOKEN=

# ── WhatsApp (optional) ───────────────────────
# Used for WhatsApp button in site and bot
# E.g. 79991234567 (no + sign)
WHATSAPP_NUMBER=

# ── Analytics (optional) ──────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
# Yandex.Metrica counter ID (numeric)
YM_COUNTER_ID=

# ── Logging ───────────────────────────────────
# Set to '1' to enable JSON structured logs (auto-enabled in production)
LOG_JSON=0
