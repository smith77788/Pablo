{
  "name": "nevesty-models",
  "version": "1.0.0",
  "description": "Nevesty Models Agency – Website + Telegram Bot",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint routes/api.js server.js utils/*.js --fix",
    "lint:all": "eslint .",
    "lint:legacy": "eslint bot.js server.js routes/api.js",
    "check": "node --check bot.js && node --check server.js && node --check routes/api.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "prepare": "husky",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "backup": "bash scripts/backup.sh"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-telegram-bot-api": "^0.64.0",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.4",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": ["eslint --fix --max-warnings=0"],
    "routes/**/*.js": ["eslint --fix"],
    "services/**/*.js": ["eslint --fix"],
    "tests/**/*.js": ["eslint --fix"]
  }
}
